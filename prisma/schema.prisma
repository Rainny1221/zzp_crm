// Prisma multi-file schema entrypoint.
// Keep only generator + datasource here.
// Put models/enums into prisma/models/*.prisma.

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     Int       @id @default(autoincrement())
  email                  String?   @db.VarChar(255)
  username               String?   @db.VarChar(255)
  first_name             String?   @db.VarChar(255)
  last_name              String?   @db.VarChar(255)
  is_verify_email        Boolean?
  password               String?
  avatar_name            String?
  background_name        String?
  created_at             DateTime  @default(now()) @db.Timestamptz(6)
  created_by             Int?
  updated_at             DateTime? @default(now()) @db.Timestamptz(6)
  updated_by             Int?
  deleted_at             DateTime? @db.Timestamptz(6)
  deleted_by             Int?
  role_id                Int?
  bio                    String?
  total_spent            Decimal?  @db.Decimal(10, 2)
  rating                 Decimal?  @db.Decimal(10, 2)
  age                    String?   @db.VarChar(255)
  platform_id            Int?
  profile_id             Int?
  contract_id            Int?
  tiktok_id              Int?
  notification_token     String?   @db.VarChar
  gender                 String?   @db.VarChar(255)
  is_block               Boolean?  @default(false)
  apple_id               String?   @db.VarChar(255)
  youtube_id             Int?
  phone_number           String?   @db.VarChar(255)
  is_new_user            Boolean?  @default(true)
  is_auth_creator_tap    Boolean?  @default(false)
  is_restricted          Boolean?  @default(false)
  have_showcase          Boolean?  @default(false)
  categories_tap         String?
  last_active_at         DateTime? @default(now()) @db.Timestamptz(6)
  channel_orientation    String[]  @default([]) @db.VarChar
  is_koc_core            Boolean?  @default(false)
  is_pinned              Boolean?  @default(false)
  is_created_external    Boolean?  @default(false)
  metadata               Json?
  is_active_ai           Boolean?
  is_high_gmv            Boolean?  @default(false)
  brand_name             String?   @db.VarChar(255)
  parent_id              Int?
  is_phone_verified      Boolean?
  is_show_page_identity  Boolean?  @default(false)
  shop_codes             String[]  @default([]) @db.VarChar
  is_active              Boolean?  @default(true)
  current_parent_user_id Int?      @db.SmallInt
  blocked_at             DateTime? @db.Timestamptz(6)

  brands_infos      brands_info[]
  file_imports      file_imports[]
  nodes             nodes[]
  platform          platforms?          @relation(fields: [platform_id], references: [id])
  role              Role?               @relation(fields: [role_id], references: [id])
  user_interacts    user_interacts[]
  user_otp_sessions user_otp_sessions[]

  crmCustomerProfile       CrmCustomerProfiles?
  ownedCrmCustomerProfiles CrmCustomerProfiles[] @relation("crm_owner")
  ownedPipelineRecords     CrmPipelineRecords[]  @relation("pipeline_owner")
  ownedCrmDeals            CrmDeals[]            @relation("deal_owner")
  crmSyncJobs              CrmSyncJobs[]

  @@map("users")
}

model Role {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(255)
  description String?   @db.VarChar(512)
  type        String?   @db.VarChar(255)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  created_by  Int?
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_by  Int?
  deleted_at  DateTime? @db.Timestamptz(6)
  deleted_by  Int?

  users           User[]
  permissionRoles PermissionRole[]

  @@map("roles")
}

model Permission {
  id         Int       @id @default(autoincrement())
  name       String?   @db.VarChar(255)
  type       String?   @db.VarChar(255)
  is_active  Boolean?  @default(true)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  created_by Int?
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_by Int?
  deleted_at DateTime? @db.Timestamptz(6)
  deleted_by Int?
  scope      String?   @db.VarChar(255)

  permissionRoles PermissionRole[]

  @@map("permissions")
}

model PermissionRole {
  id            Int @id @default(autoincrement())
  permission_id Int
  role_id       Int

  permission Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([permission_id, role_id], map: "permission_roles_un")
  @@map("permission_roles")
}

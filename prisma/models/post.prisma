model Post {
  id            Int       @id @default(autoincrement())
  content       String?   @db.VarChar(500)
  image_content String[]  @db.VarChar(255)
  like_count    Int       @default(0) @db.SmallInt
  comment_count Int       @default(0) @db.SmallInt
  published     Boolean   @default(false)
  author        User?     @relation(fields: [authorId], references: [id])
  authorId      Int
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?
  updated_by    Int?
  deleted_by    Int?
  likes         Like[]
  comments      Comment[]

  @@index([authorId])
  @@index([published, created_at])
  @@map("posts")
}

model Like {
  id         Int       @id @default(autoincrement())
  post       Post?     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId     Int
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?
  updated_by Int?
  deleted_by Int?

  @@unique([postId, userId])
  @@map("likes")
}

model Comment {
  id         Int       @id @default(autoincrement())
  post       Post?     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId     Int
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int
  content    String?   @db.VarChar(255)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?
  updated_by Int?
  deleted_by Int?

  @@index([postId])
  @@index([userId])

  @@map("comments")
}
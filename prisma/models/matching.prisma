enum UserAction {
  LIKE
  DISLIKE
  SUPERLIKE
}

enum MatchingStatus {
  PENDING
  ACCEPT
  REJECT
}

model Matching {
  id            Int            @id @default(autoincrement())
  user_1_id     Int
  user_2_id     Int
  user_1_action UserAction?
  user_2_action UserAction?
  status        MatchingStatus @default(PENDING)
  matched_at    DateTime?
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  deleted_at    DateTime?

  @@unique([user_1_id, user_2_id])
  @@index([user_1_id], map: "matching_user1_idx")
  @@index([user_2_id], map: "matching_user2_idx")
  @@index([user_1_id, matched_at])
  @@index([user_2_id, matched_at])
  @@index([user_1_id], map: "matching_user1_pending_idx", where: { status: "PENDING" })
  @@index([user_2_id], map: "matching_user2_pending_idx", where: { status: "PENDING" })
  @@map("matching_actions")
}
model CrmFeedback {
  id               Int       @id @default(autoincrement())
  category_code    String
  customer_id      Int?
  deal_id          Int?
  actor_user_id    Int?
  receiver_user_id Int?
  title            String
  message          String
  payload          Json?
  is_read          Boolean   @default(false)
  read_at          DateTime? @db.Timestamptz(6)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)

  category CrmFeedbackCategories @relation(fields: [category_code], references: [code])
  customer CrmCustomerProfiles?  @relation(fields: [customer_id], references: [id])
  deal     CrmDeals?             @relation(fields: [deal_id], references: [id])
  actor    User?                 @relation("crm_feedback_actor", fields: [actor_user_id], references: [id])
  receiver User?                 @relation("crm_feedback_receiver", fields: [receiver_user_id], references: [id])

  @@index([receiver_user_id, is_read, created_at])
  @@index([category_code, created_at])
  @@index([customer_id])
  @@index([deal_id])
  @@map("crm_feedback")
}

model CrmNotifications {
  id               Int       @id @default(autoincrement())
  type_code        String
  receiver_user_id Int
  customer_id      Int?
  deal_id          Int?
  actor_user_id    Int?
  title            String
  message          String
  payload          Json?
  is_read          Boolean   @default(false)
  read_at          DateTime? @db.Timestamptz(6)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)

  type     CrmNotificationTypes @relation(fields: [type_code], references: [code])
  receiver User                 @relation("crm_notification_receiver", fields: [receiver_user_id], references: [id])
  actor    User?                @relation("crm_notification_actor", fields: [actor_user_id], references: [id])
  customer CrmCustomerProfiles? @relation(fields: [customer_id], references: [id])
  deal     CrmDeals?            @relation(fields: [deal_id], references: [id])

  @@index([receiver_user_id, is_read, created_at])
  @@index([type_code, created_at])
  @@index([customer_id])
  @@index([deal_id])
  @@map("crm_notifications")
}

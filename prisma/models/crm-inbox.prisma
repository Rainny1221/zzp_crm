model CrmFeedbacks {
  id             Int      @id @default(autoincrement())
  customer_id    Int
  category_code  String
  content        String
  sales_user_id  Int?
  sales_name     String?
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  reads CrmFeedbackReads[]

  @@index([customer_id])
  @@index([category_code])
  @@index([sales_user_id])
  @@index([created_at])
  @@map("crm_feedbacks")
}

model CrmFeedbackReads {
  id          Int      @id @default(autoincrement())
  feedback_id Int
  user_id     Int
  read_at     DateTime @default(now()) @db.Timestamptz(6)

  feedback CrmFeedbacks @relation(fields: [feedback_id], references: [id], onDelete: Cascade)

  @@unique([feedback_id, user_id])
  @@index([user_id])
  @@map("crm_feedback_reads")
}

model CrmNotifications {
  id               Int       @id @default(autoincrement())
  type_code        String
  receiver_user_id Int
  customer_id      Int?
  deal_id          Int?
  actor_user_id    Int?
  title            String
  message          String
  payload          Json?
  is_read          Boolean   @default(false)
  read_at          DateTime? @db.Timestamptz(6)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)

  type     CrmNotificationTypes @relation(fields: [type_code], references: [code])
  receiver User                 @relation("crm_notification_receiver", fields: [receiver_user_id], references: [id])
  actor    User?                @relation("crm_notification_actor", fields: [actor_user_id], references: [id])
  customer CrmCustomerProfiles? @relation(fields: [customer_id], references: [id])
  deal     CrmDeals?            @relation(fields: [deal_id], references: [id])

  @@index([receiver_user_id, is_read, created_at])
  @@index([type_code, created_at])
  @@index([customer_id])
  @@index([deal_id])
  @@map("crm_notifications")
}

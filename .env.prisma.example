# Optional Prisma CLI override.
# Leave unset for normal local development.
# Set this only when you intentionally want Prisma CLI to target
# a different database than DATABASE_URL, for example:
# - one-time bootstrap introspection from a staging clone
# - migrate deploy in CI against staging/prod
PRISMA_DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"
